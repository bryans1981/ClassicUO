    private async Task RunSelfTestSuite()
    {
        _selfTestBusy = true;
        _selfTestReportSave = null;
        _selfTestMessage = "Running current self-test suite and saving the report locally...";

        try
        {
            var selfTestReportService = Services.GetRequiredService<BrowserHost.Services.BrowserSelfTestReportService>();
            var localReportSinkService = Services.GetRequiredService<BrowserHost.Services.BrowserLocalReportSinkService>();

            _selfTestReport = await selfTestReportService.RunAsync(
                new BrowserHost.Services.BrowserRuntimeBootstrapRequest
                {
                    TileDataPath = _sharedSeamTileDataPath,
                    ClilocPath = _sharedSeamClilocPath,
                    HuesPath = _sharedSeamHuesPath
                }
            );

            _fileSystemBridgeState = await BrowserFileSystemBridgeService.GetStateAsync();
            _selfTestReportSave = await localReportSinkService.SaveSelfTestReportAsync(_selfTestReport.Json);

            if (_selfTestReportSave.Saved)
            {
                _selfTestMessage = $"Self-test suite completed and saved locally. {_selfTestReport.Summary}";
            }
            else
            {
                _selfTestMessage = $"Self-test suite completed, but local save failed. {_selfTestReport.Summary} | saveError={_selfTestReportSave.Error}";
            }
        }
        catch (Exception ex)
        {
            try
            {
                var localReportSinkService = Services.GetRequiredService<BrowserHost.Services.BrowserLocalReportSinkService>();
                _selfTestReportSave = await localReportSinkService.SaveSelfTestFailureAsync("Self-test suite failed.", ex);
            }
            catch
            {
                _selfTestReportSave = new BrowserHost.Services.BrowserLocalReportSaveResult
                {
                    Saved = false,
                    Error = "Failure report save also failed."
                };
            }

            _selfTestMessage = $"Self-test suite failed: {ex.Message}";
        }
        finally
        {
            _selfTestBusy = false;
        }
    }

