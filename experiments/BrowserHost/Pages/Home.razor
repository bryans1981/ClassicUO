@page "/"
@inject BrowserHost.Services.EnvironmentProbeService ProbeService
@inject BrowserHost.Services.BrowserStorageService StorageService
@inject BrowserHost.Services.IBrowserClientAssetService BrowserClientAssetService
@inject BrowserHost.Services.IBrowserClientBootstrapAdapter BrowserClientBootstrapAdapter
@inject BrowserHost.Services.IBrowserClientEntrypoint BrowserClientEntrypoint
@inject BrowserHost.Services.IBrowserClientStartupIntegration BrowserClientStartupIntegration
@inject BrowserHost.Services.IBrowserClientStartupArtifacts BrowserClientStartupArtifacts
@inject BrowserHost.Services.IBrowserClientStartupArtifactReader BrowserClientStartupArtifactReader
@inject BrowserHost.Services.IBrowserClientLaunchSession BrowserClientLaunchSession
@inject BrowserHost.Services.IBrowserClientLaunchSessionReader BrowserClientLaunchSessionReader
@inject BrowserHost.Services.BrowserFileSystemBridgeService BrowserFileSystemBridgeService
@inject BrowserHost.Services.BrowserVirtualFileBridgeService BridgeService
@inject IServiceProvider Services

<PageTitle>ClassicUO Browser Spike</PageTitle>

<h1>ClassicUO Browser Spike</h1>

<p>This page verifies the first browser-hosting layer for the custom ClassicUO port.</p>

<div class="status-grid">
    <div class="status-card">
        <h2>Runtime</h2>
        <p><strong>.NET browser runtime:</strong> @FormatBool(_probe?.IsBrowserRuntime)</p>
        <p><strong>Window object:</strong> @FormatBool(_probe?.HasWindow)</p>
        <p><strong>Origin:</strong> @(_probe?.Origin ?? "not checked")</p>
    </div>

    <div class="status-card">
        <h2>Storage</h2>
        <p><strong>IndexedDB:</strong> @FormatBool(_probe?.HasIndexedDb)</p>
        <p><strong>File System Access API:</strong> @FormatBool(_probe?.HasFileSystemAccessApi)</p>
        <p><strong>OPFS API:</strong> @FormatBool(_probe?.HasOpfsApi)</p>
        <p><strong>Smoke write:</strong> @FormatBool(_storage?.WriteSucceeded)</p>
        <p><strong>Smoke read:</strong> @FormatBool(_storage?.ReadSucceeded)</p>
        <p><strong>Imported files:</strong> @(_storedFiles?.FileNames.Length ?? 0)</p>
    </div>

    <div class="status-card">
        <h2>Platform</h2>
        <p><strong>SharedArrayBuffer:</strong> @FormatBool(_probe?.HasSharedArrayBuffer)</p>
        <p><strong>User agent:</strong> @(_probe?.UserAgent ?? "not checked")</p>
    </div>
</div>

<div class="actions">
    <button class="btn btn-primary" @onclick="RunProbe" disabled="@_isBusy">@(_isBusy ? "Running..." : "Run environment probe")</button>
    <button class="btn btn-secondary ms-2" @onclick="RunStorageSmokeTest" disabled="@_storageBusy">@(_storageBusy ? "Testing..." : "Run OPFS smoke test")</button>
    <button class="btn btn-success ms-2" @onclick="ImportFiles" disabled="@_importBusy">@(_importBusy ? "Importing..." : "Import files to /uo")</button>
    <button class="btn btn-success ms-2" @onclick="ImportDirectory" disabled="@_directoryImportBusy">@(_directoryImportBusy ? "Importing..." : "Import folder to /uo")</button>
    <button class="btn btn-success ms-2" @onclick="ImportHostedSeed" disabled="@_hostedSeedImportBusy">@(_hostedSeedImportBusy ? "Importing..." : "Import local seed to /uo")</button>
    <button class="btn btn-success ms-2" @onclick="ImportHostedRecommendedSeed" disabled="@_hostedSeedRecommendedImportBusy">@(_hostedSeedRecommendedImportBusy ? "Importing..." : "Import recommended seed to /uo")</button>
    <button class="btn btn-danger ms-2" @onclick="ResetStorage" disabled="@_resetBusy">@(_resetBusy ? "Resetting..." : "Reset OPFS storage")</button>
    <button class="btn btn-outline-secondary ms-2" @onclick="RefreshFiles" disabled="@_refreshBusy">@(_refreshBusy ? "Refreshing..." : "Refresh stored files")</button>
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <p class="message">@_message</p>
}

@if (!string.IsNullOrWhiteSpace(_storageMessage))
{
    <p class="message">@_storageMessage</p>
}

@if (!string.IsNullOrWhiteSpace(_importMessage))
{
    <p class="message">@_importMessage</p>
}

<div class="tab-bar">
    <button class="@GetTabClass("current")" @onclick='() => SetActiveTab("current")'>Current Tests</button>
    <button class="@GetTabClass("imports")" @onclick='() => SetActiveTab("imports")'>Imports & Assets</button>
    <button class="@GetTabClass("diagnostics")" @onclick='() => SetActiveTab("diagnostics")'>Archived Tests</button>
</div>

@if (_activeTab == "current")
{
<div class="next-steps">
    <h2>Current Self-Test Suite</h2>
    <p>This runs the current browser bootstrap checks in one batch and can export a JSON report.</p>

    <div class="actions">
        <button class="btn btn-primary" @onclick="RunSelfTestSuite" disabled="@_selfTestBusy">@(_selfTestBusy ? "Running..." : "Run current self-test suite")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_selfTestMessage))
    {
        <p class="message">@_selfTestMessage</p>
    }

    @if (_selfTestReport is not null)
    {
        <p><strong>Generated:</strong> @_selfTestReport.GeneratedAtUtc.ToString("u")</p>
        <p><strong>Report mode:</strong> @_selfTestReport.ReportMode</p>
        <p><strong>Newest layers:</strong> operational stability, steady operation readiness</p>
        <p><strong>Runtime chain marker:</strong> @_selfTestReport.RuntimeChainMarker</p>
        <p><strong>Summary:</strong> @_selfTestReport.Summary</p>
