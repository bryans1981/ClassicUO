    private async Task ProbeBridgePath()
    {
        _bridgeBusy = true;
        _bridgeMessage = $"Reading virtual path '{_bridgePath}'...";

        try
        {
            _bridgeProbe = await BridgeService.ProbePathAsync(_bridgePath);
            _bridgeMessage = string.IsNullOrWhiteSpace(_bridgeProbe.Error)
                ? $"Bridge probe completed for {_bridgeProbe.Path}."
                : $"Bridge probe finished with error: {_bridgeProbe.Error}";
        }
        catch (Exception ex)
        {
            _bridgeMessage = $"Bridge probe failed: {ex.Message}";
        }
        finally
        {
            _bridgeBusy = false;
        }
    }

    private async Task ResetStorage()
    {
        _resetBusy = true;
        _importMessage = "Resetting browser OPFS storage...";

        try
        {
            var result = await StorageService.ResetStorageAsync();
            _importMessage = string.IsNullOrWhiteSpace(result.Error)
                ? $"Reset completed. Removed {result.DeletedEntries} stored item(s)."
                : $"Reset finished with error: {result.Error}";

            _bridgeProbe = null;
            _bridgeWriteResult = null;
            await RefreshFiles();
        }
        catch (Exception ex)
        {
            _importMessage = $"Reset failed: {ex.Message}";
        }
        finally
        {
            _resetBusy = false;
        }
    }

    private async Task WriteBridgeProbe()
    {
        _bridgeWriteBusy = true;
        _bridgeMessage = $"Writing probe file to '{_bridgePath}'...";

        try
        {
            _bridgeWriteResult = await BridgeService.WriteTextProbeAsync(_bridgePath, _bridgeWriteText);
            _bridgeMessage = string.IsNullOrWhiteSpace(_bridgeWriteResult.Error)
                ? $"Bridge write completed for {_bridgeWriteResult.Path}."
                : $"Bridge write finished with error: {_bridgeWriteResult.Error}";
            await RefreshFiles();
            _bridgeProbe = await BridgeService.ProbePathAsync(_bridgePath);
        }
        catch (Exception ex)
        {
            _bridgeMessage = $"Bridge write failed: {ex.Message}";
        }
        finally
        {
            _bridgeWriteBusy = false;
        }
    }

