    private async Task ClearPreloadCache()
    {
        _preloadClearBusy = true;
        _preloadMessage = "Clearing preload cache...";

        try
        {
            _preloadResult = await StorageService.ClearPreloadCacheAsync();
            _preloadSummary = await StorageService.GetPreloadCacheSummaryAsync();
