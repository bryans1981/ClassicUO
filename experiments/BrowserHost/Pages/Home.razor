            <p><strong>Saved locally:</strong> @FormatBool(_selfTestReportSave.Saved)</p>
            <p><strong>Latest report path:</strong> @(_selfTestReportSave.LatestPath ?? "(not saved)")</p>
            <p><strong>Saved at:</strong> @(_selfTestReportSave.SavedAtUtc == default ? "(unknown)" : _selfTestReportSave.SavedAtUtc.ToString("u"))</p>
        }
