        <p><strong>Raw cache entries:</strong> @_selfTestReport.CacheState.RawAssetCache.EntryCount</p>
        <p><strong>Processed cache entries:</strong> @_selfTestReport.CacheState.ProcessedAssetCache.EntryCount</p>
        <p><strong>Bridge loaded paths:</strong> @_selfTestReport.BridgeState.LoadedCount</p>
        <p><strong>Startup artifact write:</strong> @FormatBool(_selfTestReport.StartupArtifact.WriteSucceeded)</p>
        <p><strong>Startup artifact read:</strong> @FormatBool(_selfTestReport.StartupArtifactRead.ReadSucceeded)</p>
        <p><strong>Launch session write:</strong> @FormatBool(_selfTestReport.LaunchSession.WriteSucceeded)</p>
        <p><strong>Launch session read:</strong> @FormatBool(_selfTestReport.LaunchSessionRead.ReadSucceeded)</p>
        <p><strong>Browser bootstrap package ready:</strong> @FormatBool(_selfTestReport.BootstrapPackage.IsReady)</p>
        <p><strong>Browser bootstrap package artifact:</strong> @_selfTestReport.BootstrapPackage.ArtifactPath</p>
        <p><strong>Runtime contract ready:</strong> @FormatBool(_selfTestReport.RuntimeLaunchContract.IsReady)</p>
        <p><strong>Startup packet ready:</strong> @FormatBool(_selfTestReport.StartupPacket.IsReady)</p>
        <p><strong>Startup consumer ready:</strong> @FormatBool(_selfTestReport.StartupConsumer.IsReady)</p>
        <p><strong>Startup executor ready:</strong> @FormatBool(_selfTestReport.StartupSessionExecutor.IsReady)</p>
        <p><strong>Startup runner ready:</strong> @FormatBool(_selfTestReport.StartupSessionRunner.IsReady)</p>
        <p><strong>Runtime loop ready:</strong> @FormatBool(_selfTestReport.RuntimeBootstrapLoop.IsReady)</p>
        <p><strong>Runtime invocation ready:</strong> @FormatBool(_selfTestReport.RuntimeInvocation.IsReady)</p>
        <p><strong>Runtime cycle ready:</strong> @FormatBool(_selfTestReport.RuntimeStartupCycle.IsReady)</p>
        <p><strong>Runtime state ready:</strong> @FormatBool(_selfTestReport.RuntimeStartupState.IsReady)</p>
        <p><strong>Runtime state machine ready:</strong> @FormatBool(_selfTestReport.RuntimeStartupStateMachine.IsReady)</p>
        <p><strong>Runtime transition driver ready:</strong> @FormatBool(_selfTestReport.RuntimeStartupTransitionDriver.IsReady)</p>
        <p><strong>Runtime dispatcher ready:</strong> @FormatBool(_selfTestReport.RuntimeStartupDispatcher.IsReady)</p>
        <p><strong>Runtime session controller ready:</strong> @FormatBool(_selfTestReport.RuntimeStartupSessionController.IsReady)</p>
        <p><strong>Runtime coordinator ready:</strong> @FormatBool(_selfTestReport.RuntimeStartupCoordinator.IsReady)</p>
        <p><strong>Runtime orchestrator ready:</strong> @FormatBool(_selfTestReport.RuntimeStartupOrchestrator.IsReady)</p>
        <p><strong>Browser boot flow ready:</strong> @FormatBool(_selfTestReport.BrowserBootFlowController.IsReady)</p>
        <p><strong>Browser boot session ready:</strong> @FormatBool(_selfTestReport.BrowserBootSession.IsReady)</p>
        <p><strong>Runtime launch handoff ready:</strong> @FormatBool(_selfTestReport.RuntimeLaunchHandoff.IsReady)</p>
        <p><strong>Runtime bootstrap consumer ready:</strong> @FormatBool(_selfTestReport.RuntimeBootstrapConsumer.IsReady)</p>
        <p><strong>Runtime bootstrap session ready:</strong> @FormatBool(_selfTestReport.RuntimeBootstrapSession.IsReady)</p>
        <p><strong>Runtime client bootstrap ready:</strong> @FormatBool(_selfTestReport.RuntimeClientBootstrapController.IsReady)</p>
        <p><strong>Runtime readiness gate ready:</strong> @FormatBool(_selfTestReport.RuntimeStartupReadinessGate.IsReady)</p>
        <p><strong>Runtime ready signal ready:</strong> @FormatBool(_selfTestReport.RuntimeReadySignal.IsReady)</p>
        <p><strong>Runtime launch controller ready:</strong> @FormatBool(_selfTestReport.RuntimeLaunchController.IsReady)</p>
        <p><strong>Runtime client ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeClientReadyState.IsReady)</p>
        <p><strong>Runtime client launch session ready:</strong> @FormatBool(_selfTestReport.RuntimeClientLaunchSession.IsReady)</p>
        <p><strong>Runtime client activation ready:</strong> @FormatBool(_selfTestReport.RuntimeClientActivation.IsReady)</p>
        <p><strong>Runtime client run state ready:</strong> @FormatBool(_selfTestReport.RuntimeClientRunState.IsReady)</p>
        <p><strong>Runtime client loop state ready:</strong> @FormatBool(_selfTestReport.RuntimeClientLoopState.IsReady)</p>
        <p><strong>Runtime host session ready:</strong> @FormatBool(_selfTestReport.RuntimeHostSession.IsReady)</p>
        <p><strong>Runtime host loop ready:</strong> @FormatBool(_selfTestReport.RuntimeHostLoop.IsReady)</p>
        <p><strong>Runtime host ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeHostReadyState.IsReady)</p>
        <p><strong>Runtime platform session ready:</strong> @FormatBool(_selfTestReport.RuntimePlatformSession.IsReady)</p>
        <p><strong>Runtime platform ready state ready:</strong> @FormatBool(_selfTestReport.RuntimePlatformReadyState.IsReady)</p>
        <p><strong>Runtime platform loop ready:</strong> @FormatBool(_selfTestReport.RuntimePlatformLoop.IsReady)</p>
        <p><strong>Runtime platform launch gate ready:</strong> @FormatBool(_selfTestReport.RuntimePlatformLaunchGate.IsReady)</p>
        <p><strong>Runtime browser shell session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserShellSession.IsReady)</p>
        <p><strong>Runtime browser shell ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserShellReadyState.IsReady)</p>
        <p><strong>Runtime browser surface session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserSurfaceSession.IsReady)</p>
        <p><strong>Runtime browser surface ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserSurfaceReadyState.IsReady)</p>
        <p><strong>Runtime browser window session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserWindowSession.IsReady)</p>
        <p><strong>Runtime browser window ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserWindowReadyState.IsReady)</p>
        <p><strong>Runtime browser frame session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserFrameSession.IsReady)</p>
        <p><strong>Runtime browser frame ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserFrameReadyState.IsReady)</p>
        <p><strong>Runtime browser canvas session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserCanvasSession.IsReady)</p>
        <p><strong>Runtime browser canvas ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserCanvasReadyState.IsReady)</p>
        <p><strong>Runtime browser render session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserRenderSession.IsReady)</p>
        <p><strong>Runtime browser render ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserRenderReadyState.IsReady)</p>
        <p><strong>Runtime browser present session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserPresentSession.IsReady)</p>
        <p><strong>Runtime browser present ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserPresentReadyState.IsReady)</p>
        <p><strong>Runtime browser display session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserDisplaySession.IsReady)</p>
        <p><strong>Runtime browser display ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserDisplayReadyState.IsReady)</p>
        <p><strong>Runtime browser viewport session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserViewportSession.IsReady)</p>
        <p><strong>Runtime browser viewport ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserViewportReadyState.IsReady)</p>
        <p><strong>Runtime browser scene session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserSceneSession.IsReady)</p>
        <p><strong>Runtime browser scene ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserSceneReadyState.IsReady)</p>
        <p><strong>Runtime browser input session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserInputSession.IsReady)</p>
        <p><strong>Runtime browser input ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserInputReadyState.IsReady)</p>
        <p><strong>Runtime browser event session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserEventSession.IsReady)</p>
        <p><strong>Runtime browser event ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserEventReadyState.IsReady)</p>
        <p><strong>Runtime browser interaction session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserInteractionSession.IsReady)</p>
        <p><strong>Runtime browser interaction ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserInteractionReadyState.IsReady)</p>
        <p><strong>Runtime browser focus session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserFocusSession.IsReady)</p>
        <p><strong>Runtime browser focus ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserFocusReadyState.IsReady)</p>
        <p><strong>Runtime browser shortcut session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserShortcutSession.IsReady)</p>
        <p><strong>Runtime browser shortcut ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserShortcutReadyState.IsReady)</p>
        <p><strong>Runtime browser pointer session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserPointerSession.IsReady)</p>
        <p><strong>Runtime browser pointer ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserPointerReadyState.IsReady)</p>
        <p><strong>Runtime browser command session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserCommandSession.IsReady)</p>
        <p><strong>Runtime browser command ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserCommandReadyState.IsReady)</p>
        <p><strong>Runtime browser gesture session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserGestureSession.IsReady)</p>
        <p><strong>Runtime browser gesture ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserGestureReadyState.IsReady)</p>
        <p><strong>Runtime browser lifecycle session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserLifecycleSession.IsReady)</p>
        <p><strong>Runtime browser lifecycle ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserLifecycleReadyState.IsReady)</p>
        <p><strong>Runtime browser route session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserRouteSession.IsReady)</p>
        <p><strong>Runtime browser route ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserRouteReadyState.IsReady)</p>
        <p><strong>Runtime browser state-sync session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserStateSyncSession.IsReady)</p>
        <p><strong>Runtime browser state-sync ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserStateSyncReadyState.IsReady)</p>
        <p><strong>Runtime browser restore session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserRestoreSession.IsReady)</p>
        <p><strong>Runtime browser restore ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserRestoreReadyState.IsReady)</p>
        <p><strong>Runtime browser resume session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserResumeSession.IsReady)</p>
        <p><strong>Runtime browser resume ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserResumeReadyState.IsReady)</p>
        <p><strong>Runtime browser live persistence session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserLivePersistenceSession.IsReady)</p>
        <p><strong>Runtime browser live persistence ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserLivePersistenceReadyState.IsReady)</p>
        <p><strong>Runtime browser steady persistence readiness session ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserSteadyPersistenceReadinessSession.IsReady)</p>
        <p><strong>Runtime browser steady persistence readiness ready state ready:</strong> @FormatBool(_selfTestReport.RuntimeBrowserSteadyPersistenceReadinessReadyState.IsReady)</p>
        <p><strong>Runtime tail extension ready:</strong> @FormatBool(_selfTestReport.RuntimeTailExtension.IsReady)</p>
        <p><strong>Runtime tail extension version:</strong> @_selfTestReport.RuntimeTailExtension.ExtensionVersion</p>
        <p><strong>Runtime tail extension phases:</strong> @string.Join(", ", _selfTestReport.RuntimeTailExtension.Phases)</p>
    }
</div>

@if (_assetManifest?.Bootstrap is not null)
{
    <div class="next-steps">
        <h2>Bootstrap readiness</h2>
        <p>This is a stricter browser-port check than the current desktop startup guard, intended to tell us whether `/uo` looks usable for a first real asset-read path.</p>
        <p><strong>Ready:</strong> @FormatBool(_assetManifest.Bootstrap.IsReady)</p>
        <p><strong>Checks passed:</strong> @_assetManifest.Bootstrap.PassedChecks / @_assetManifest.Bootstrap.TotalChecks</p>
        <p><strong>Primary read target:</strong> @(string.IsNullOrWhiteSpace(_assetManifest.Bootstrap.PrimaryReadTargetPath) ? "not ready" : _assetManifest.Bootstrap.PrimaryReadTargetPath)</p>
        <p><strong>Reason:</strong> @_assetManifest.Bootstrap.PrimaryReadTargetReason</p>
        <p><strong>Recommended minimal import set:</strong> @string.Join(", ", _assetManifest.Bootstrap.RecommendedImportSet)</p>

        @if (_assetManifest.Bootstrap.MissingRecommendedFiles.Length > 0)
        {
            <p><strong>Missing recommended files:</strong> @string.Join(", ", _assetManifest.Bootstrap.MissingRecommendedFiles)</p>
        }
        else
        {
            <p><strong>Missing recommended files:</strong> none</p>
        }

        @foreach (var check in _assetManifest.Bootstrap.Checks)
        {
            <p><strong>@check.Name:</strong> @FormatBool(check.IsSatisfied)</p>
            <p>@check.Description</p>
            <p><strong>Accepted:</strong> @string.Join(", ", check.AcceptedPatterns)</p>
            <p><strong>Matches:</strong> @(check.Matches.Length == 0 ? "none" : string.Join(", ", check.Matches))</p>
        }
    </div>
}

<div class="next-steps">
    <h2>Shared filesystem bridge</h2>
    <p>This loads the current bootstrap asset set into a read-only shared `BrowserFileSystem` provider so the browser-host path can be validated through the real seam instead of spike-only readers.</p>

    <div class="mb-2">
        <label><strong>Bridge probe path:</strong></label>
        <input class="form-control" @bind="_fileSystemBridgePath" />
    </div>

    <div class="actions">
        <button class="btn btn-primary" @onclick="ActivateFileSystemBridge" disabled="@_fileSystemBridgeBusy">@(_fileSystemBridgeBusy ? "Activating..." : "Activate bridge from bootstrap assets")</button>
        <button class="btn btn-outline-secondary ms-2" @onclick="ProbeFileSystemBridge" disabled="@_fileSystemBridgeProbeBusy">@(_fileSystemBridgeProbeBusy ? "Probing..." : "Probe shared filesystem path")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_fileSystemBridgeMessage))
    {
        <p class="message">@_fileSystemBridgeMessage</p>
    }

    @if (_fileSystemBridgeState is not null)
    {
        <p><strong>Activated:</strong> @FormatBool(_fileSystemBridgeState.Activated)</p>
        <p><strong>Loaded paths:</strong> @_fileSystemBridgeState.LoadedCount</p>

        @if (_fileSystemBridgeState.LoadedPaths.Length > 0)
        {
            <p><strong>Bridge assets:</strong> @string.Join(", ", _fileSystemBridgeState.LoadedPaths)</p>
        }
    }

    @if (_fileSystemBridgeProbe is not null)
    {
        <p><strong>Probe path:</strong> @_fileSystemBridgeProbe.Path</p>
        <p><strong>Exists:</strong> @FormatBool(_fileSystemBridgeProbe.Exists)</p>
        <p><strong>Loaded on demand:</strong> @FormatBool(_fileSystemBridgeProbe.LoadedOnDemand)</p>
        <p><strong>Read succeeded:</strong> @FormatBool(_fileSystemBridgeProbe.ReadSucceeded)</p>
        <p><strong>Bytes:</strong> @_fileSystemBridgeProbe.Length</p>
        <p><strong>Total ms:</strong> @_fileSystemBridgeProbe.TotalMs.ToString("0.00")</p>

        @if (!string.IsNullOrWhiteSpace(_fileSystemBridgeProbe.Error))
        {
            <p><strong>Error:</strong> @_fileSystemBridgeProbe.Error</p>
        }
    }
</div>

<div class="next-steps">
    <h2>Browser bootstrap handoff</h2>
    <p>This is the first entrypoint-oriented payload built from the seam runtime state instead of test-specific result models.</p>

    <div class="actions">
        <button class="btn btn-primary" @onclick="LoadBrowserBootstrapHandoff" disabled="@_browserBootstrapHandoffBusy">@(_browserBootstrapHandoffBusy ? "Loading..." : "Load browser bootstrap handoff")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_browserBootstrapHandoffMessage))
    {
        <p class="message">@_browserBootstrapHandoffMessage</p>
    }

    @if (_browserBootstrapHandoff is not null)
    {
        <p><strong>Ready:</strong> @FormatBool(_browserBootstrapHandoff.IsReady)</p>
        <p><strong>Ready assets:</strong> @_browserBootstrapHandoff.ReadyAssetCount / 3</p>
        <p><strong>Cache hits:</strong> @_browserBootstrapHandoff.CacheHits</p>
        <p><strong>Total ms:</strong> @_browserBootstrapHandoff.TotalMs.ToString("0.00")</p>
        <p><strong>Summary:</strong> @_browserBootstrapHandoff.Summary</p>
    }
</div>

<div class="next-steps">
    <h2>Browser startup context</h2>
    <p>This is the first startup-oriented adapter output built from the seam-backed handoff for a future ClassicUO browser entrypoint.</p>

    <div class="actions">
        <button class="btn btn-primary" @onclick="LoadBrowserStartupContext" disabled="@_browserStartupContextBusy">@(_browserStartupContextBusy ? "Loading..." : "Load browser startup context")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_browserStartupContextMessage))
    {
        <p class="message">@_browserStartupContextMessage</p>
    }

    @if (_browserStartupContext is not null)
    {
        <p><strong>Ready:</strong> @FormatBool(_browserStartupContext.IsReady)</p>
        <p><strong>Ready assets:</strong> @_browserStartupContext.ReadyAssetCount / 3</p>
        <p><strong>Total ms:</strong> @_browserStartupContext.TotalMs.ToString("0.00")</p>
        <p><strong>Summary:</strong> @_browserStartupContext.Summary</p>
    }
</div>

<div class="next-steps">
    <h2>Browser launch plan</h2>
    <p>This prepares minimal browser-side config/profile files and reports whether startup can proceed.</p>

    <div class="actions">
        <button class="btn btn-primary" @onclick="LoadBrowserLaunchPlan" disabled="@_browserLaunchPlanBusy">@(_browserLaunchPlanBusy ? "Loading..." : "Load browser launch plan")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_browserLaunchPlanMessage))
    {
        <p class="message">@_browserLaunchPlanMessage</p>
    }

    @if (_browserLaunchPlan is not null)
    {
        <p><strong>Ready:</strong> @FormatBool(_browserLaunchPlan.IsReady)</p>
        <p><strong>Settings prepared:</strong> @FormatBool(_browserLaunchPlan.SettingsPrepared)</p>
        <p><strong>Profile prepared:</strong> @FormatBool(_browserLaunchPlan.StartupProfilePrepared)</p>
        <p><strong>Total ms:</strong> @_browserLaunchPlan.TotalMs.ToString("0.00")</p>
        <p><strong>Summary:</strong> @_browserLaunchPlan.Summary</p>
    }
</div>

<div class="next-steps">
    <h2>Browser startup run</h2>
    <p>This groups the launch plan into explicit startup steps for a future browser entrypoint.</p>

    <div class="actions">
        <button class="btn btn-primary" @onclick="LoadBrowserStartupRun" disabled="@_browserStartupRunBusy">@(_browserStartupRunBusy ? "Loading..." : "Load browser startup run")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_browserStartupRunMessage))
    {
        <p class="message">@_browserStartupRunMessage</p>
    }

    @if (_browserStartupRun is not null)
    {
        <p><strong>Ready:</strong> @FormatBool(_browserStartupRun.IsReady)</p>
        <p><strong>Completed steps:</strong> @_browserStartupRun.CompletedSteps / @_browserStartupRun.TotalSteps</p>
        <p><strong>Total ms:</strong> @_browserStartupRun.TotalMs.ToString("0.00")</p>
        <p><strong>Summary:</strong> @_browserStartupRun.Summary</p>
    }
</div>

<div class="next-steps">
    <h2>Browser startup artifact</h2>
    <p>This writes the startup run into browser storage as a real launch-state artifact.</p>

    <div class="actions">
        <button class="btn btn-primary" @onclick="CreateBrowserStartupArtifact" disabled="@_browserStartupArtifactBusy">@(_browserStartupArtifactBusy ? "Writing..." : "Create browser startup artifact")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_browserStartupArtifactMessage))
    {
        <p class="message">@_browserStartupArtifactMessage</p>
    }

    @if (_browserStartupArtifact is not null)
    {
        <p><strong>Ready:</strong> @FormatBool(_browserStartupArtifact.IsReady)</p>
        <p><strong>Write succeeded:</strong> @FormatBool(_browserStartupArtifact.WriteSucceeded)</p>
        <p><strong>Artifact path:</strong> @_browserStartupArtifact.ArtifactPath</p>
        <p><strong>Total ms:</strong> @_browserStartupArtifact.TotalMs.ToString("0.00")</p>
        <p><strong>Summary:</strong> @_browserStartupArtifact.Summary</p>
