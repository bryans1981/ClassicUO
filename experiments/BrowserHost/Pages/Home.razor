    private async Task LoadBootstrapSnapshot()
    {
        _loaderSnapshotBusy = true;
        _loaderSnapshotMessage = "Loading bootstrap asset snapshot...";

        try
        {
            _loaderSnapshot = await BrowserClientAssetService.GetBootstrapStateAsync(
                new BrowserHost.Services.BrowserRuntimeBootstrapRequest
                {
                    TileDataPath = _tileDataPath,
                    ClilocPath = _clilocPath,
                    HuesPath = _huesPath
                }
            );

            _loaderSnapshotMessage = $"Bootstrap snapshot completed in {_loaderSnapshot.TotalMs:0.00} ms.";
        }
        catch (Exception ex)
        {
            _loaderSnapshotMessage = $"Bootstrap snapshot failed: {ex.Message}";
        }
        finally
        {
            _loaderSnapshotBusy = false;
        }
    }

    private async Task WarmAssetPath()
    {
        _assetWarmBusy = true;
        _assetWarmMessage = $"Warming {_assetWarmPath} into the C# asset stream cache...";

        try
        {
            _assetWarmResult = await BrowserClientAssetService.WarmAssetAsync(_assetWarmPath);
            _runtimeCacheState = await BrowserClientAssetService.GetCacheStateAsync();
            _assetWarmMessage = string.IsNullOrWhiteSpace(_assetWarmResult.Error)
                ? $"Asset warm completed for {_assetWarmResult.Path}."
                : $"Asset warm finished with error: {_assetWarmResult.Error}";
        }
        catch (Exception ex)
        {
            _assetWarmMessage = $"Asset warm failed: {ex.Message}";
        }
        finally
        {
            _assetWarmBusy = false;
        }
    }

    private async Task ClearAssetSourceCache()
    {
        _assetCacheClearBusy = true;
        _assetWarmMessage = "Clearing the C# asset stream cache...";

        try
        {
            await BrowserClientAssetService.ClearCachesAsync();
            _assetWarmResult = null;
            _runtimeCacheState = await BrowserClientAssetService.GetCacheStateAsync();
            _assetWarmMessage = "Asset stream cache cleared.";
        }
        catch (Exception ex)
        {
            _assetWarmMessage = $"Clear asset stream cache failed: {ex.Message}";
        }
        finally
        {
            _assetCacheClearBusy = false;
        }
    }

