    private static string FormatBool(bool? value)
    {
        return value switch
        {
            true => "yes",
            false => "no",
            _ => "not checked"
        };
    }

    private void SetActiveTab(string tab)
    {
        _activeTab = tab;
    }

    private string GetTabClass(string tab)
    {
        return _activeTab == tab ? "tab-button tab-button-active" : "tab-button";
    }
