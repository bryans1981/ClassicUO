@page "/"
@inject BrowserHost.Services.EnvironmentProbeService ProbeService
@inject BrowserHost.Services.BrowserStorageService StorageService
@inject BrowserHost.Services.IBrowserClientAssetService BrowserClientAssetService
@inject BrowserHost.Services.BrowserVirtualFileBridgeService BridgeService

<PageTitle>ClassicUO Browser Spike</PageTitle>

<h1>ClassicUO Browser Spike</h1>

<p>This page verifies the first browser-hosting layer for the custom ClassicUO port.</p>

<div class="status-grid">
    <div class="status-card">
        <h2>Runtime</h2>
        <p><strong>.NET browser runtime:</strong> @FormatBool(_probe?.IsBrowserRuntime)</p>
        <p><strong>Window object:</strong> @FormatBool(_probe?.HasWindow)</p>
        <p><strong>Origin:</strong> @(_probe?.Origin ?? "not checked")</p>
    </div>

    <div class="status-card">
        <h2>Storage</h2>
        <p><strong>IndexedDB:</strong> @FormatBool(_probe?.HasIndexedDb)</p>
        <p><strong>File System Access API:</strong> @FormatBool(_probe?.HasFileSystemAccessApi)</p>
        <p><strong>OPFS API:</strong> @FormatBool(_probe?.HasOpfsApi)</p>
        <p><strong>Smoke write:</strong> @FormatBool(_storage?.WriteSucceeded)</p>
        <p><strong>Smoke read:</strong> @FormatBool(_storage?.ReadSucceeded)</p>
        <p><strong>Imported files:</strong> @(_storedFiles?.FileNames.Length ?? 0)</p>
    </div>

    <div class="status-card">
        <h2>Platform</h2>
        <p><strong>SharedArrayBuffer:</strong> @FormatBool(_probe?.HasSharedArrayBuffer)</p>
        <p><strong>User agent:</strong> @(_probe?.UserAgent ?? "not checked")</p>
    </div>
</div>

<div class="actions">
    <button class="btn btn-primary" @onclick="RunProbe" disabled="@_isBusy">@(_isBusy ? "Running..." : "Run environment probe")</button>
    <button class="btn btn-secondary ms-2" @onclick="RunStorageSmokeTest" disabled="@_storageBusy">@(_storageBusy ? "Testing..." : "Run OPFS smoke test")</button>
    <button class="btn btn-success ms-2" @onclick="ImportFiles" disabled="@_importBusy">@(_importBusy ? "Importing..." : "Import files to /uo")</button>
    <button class="btn btn-success ms-2" @onclick="ImportDirectory" disabled="@_directoryImportBusy">@(_directoryImportBusy ? "Importing..." : "Import folder to /uo")</button>
    <button class="btn btn-success ms-2" @onclick="ImportHostedSeed" disabled="@_hostedSeedImportBusy">@(_hostedSeedImportBusy ? "Importing..." : "Import local seed to /uo")</button>
    <button class="btn btn-success ms-2" @onclick="ImportHostedRecommendedSeed" disabled="@_hostedSeedRecommendedImportBusy">@(_hostedSeedRecommendedImportBusy ? "Importing..." : "Import recommended seed to /uo")</button>
    <button class="btn btn-danger ms-2" @onclick="ResetStorage" disabled="@_resetBusy">@(_resetBusy ? "Resetting..." : "Reset OPFS storage")</button>
    <button class="btn btn-outline-secondary ms-2" @onclick="RefreshFiles" disabled="@_refreshBusy">@(_refreshBusy ? "Refreshing..." : "Refresh stored files")</button>
</div>

@if (!string.IsNullOrWhiteSpace(_message))
{
    <p class="message">@_message</p>
}

@if (!string.IsNullOrWhiteSpace(_storageMessage))
{
    <p class="message">@_storageMessage</p>
}

@if (!string.IsNullOrWhiteSpace(_importMessage))
{
    <p class="message">@_importMessage</p>
}

<div class="tab-bar">
    <button class="@GetTabClass("current")" @onclick='() => SetActiveTab("current")'>Current Tests</button>
    <button class="@GetTabClass("imports")" @onclick='() => SetActiveTab("imports")'>Imports & Assets</button>
    <button class="@GetTabClass("diagnostics")" @onclick='() => SetActiveTab("diagnostics")'>Diagnostics</button>
</div>

@if (_activeTab == "current")
{
@if (_assetManifest?.Bootstrap is not null)
{
    <div class="next-steps">
        <h2>Bootstrap readiness</h2>
        <p>This is a stricter browser-port check than the current desktop startup guard, intended to tell us whether `/uo` looks usable for a first real asset-read path.</p>
        <p><strong>Ready:</strong> @FormatBool(_assetManifest.Bootstrap.IsReady)</p>
        <p><strong>Checks passed:</strong> @_assetManifest.Bootstrap.PassedChecks / @_assetManifest.Bootstrap.TotalChecks</p>
        <p><strong>Primary read target:</strong> @(string.IsNullOrWhiteSpace(_assetManifest.Bootstrap.PrimaryReadTargetPath) ? "not ready" : _assetManifest.Bootstrap.PrimaryReadTargetPath)</p>
        <p><strong>Reason:</strong> @_assetManifest.Bootstrap.PrimaryReadTargetReason</p>
        <p><strong>Recommended minimal import set:</strong> @string.Join(", ", _assetManifest.Bootstrap.RecommendedImportSet)</p>

        @if (_assetManifest.Bootstrap.MissingRecommendedFiles.Length > 0)
        {
            <p><strong>Missing recommended files:</strong> @string.Join(", ", _assetManifest.Bootstrap.MissingRecommendedFiles)</p>
        }
        else
        {
            <p><strong>Missing recommended files:</strong> none</p>
        }

        @foreach (var check in _assetManifest.Bootstrap.Checks)
        {
            <p><strong>@check.Name:</strong> @FormatBool(check.IsSatisfied)</p>
            <p>@check.Description</p>
            <p><strong>Accepted:</strong> @string.Join(", ", check.AcceptedPatterns)</p>
            <p><strong>Matches:</strong> @(check.Matches.Length == 0 ? "none" : string.Join(", ", check.Matches))</p>
        }
    </div>
}

<div class="next-steps">
    <h2>Bootstrap loader snapshot</h2>
    <p>This runs the current browser-side bootstrap asset set together through the loader service and reports one combined result.</p>

    <div class="actions">
        <button class="btn btn-primary" @onclick="LoadBootstrapSnapshot" disabled="@_loaderSnapshotBusy">@(_loaderSnapshotBusy ? "Loading..." : "Load bootstrap snapshot")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_loaderSnapshotMessage))
    {
        <p class="message">@_loaderSnapshotMessage</p>
    }

    @if (_loaderSnapshot is not null)
    {
        <p><strong>Loaded assets:</strong> @_loaderSnapshot.LoadedCount / 3</p>
        <p><strong>Cache hits:</strong> @_loaderSnapshot.CacheHits</p>
        <p><strong>Total ms:</strong> @_loaderSnapshot.TotalMs.ToString("0.00")</p>
        <p><strong>Ready:</strong> @FormatBool(_loaderSnapshot.IsReady)</p>
        <p><strong>Tiledata:</strong> @FormatBool(_loaderSnapshot.TileData.Exists)</p>
        <p><strong>Cliloc:</strong> @FormatBool(_loaderSnapshot.Cliloc.Exists)</p>
        <p><strong>Hues:</strong> @FormatBool(_loaderSnapshot.Hues.Exists)</p>
    }
</div>

<div class="next-steps">
    <h2>Asset stream cache</h2>
    <p>This is the reusable C# binary cache that sits behind the browser asset stream source and avoids repeated JS/base64 reads for warmed files.</p>

    <div class="mb-2">
        <label><strong>Warm path:</strong></label>
        <input class="form-control" @bind="_assetWarmPath" />
    </div>

    <div class="actions">
        <button class="btn btn-secondary" @onclick="WarmAssetPath" disabled="@_assetWarmBusy">@(_assetWarmBusy ? "Warming..." : "Warm asset path")</button>
        <button class="btn btn-outline-danger ms-2" @onclick="ClearAssetSourceCache" disabled="@_assetCacheClearBusy">@(_assetCacheClearBusy ? "Clearing..." : "Clear asset stream cache")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_assetWarmMessage))
    {
        <p class="message">@_assetWarmMessage</p>
    }

    @if (_assetWarmResult is not null)
    {
        <p><strong>Path:</strong> @_assetWarmResult.Path</p>
        <p><strong>Succeeded:</strong> @FormatBool(_assetWarmResult.Succeeded)</p>
        <p><strong>Was cached:</strong> @FormatBool(_assetWarmResult.WasCached)</p>
        <p><strong>Bytes:</strong> @_assetWarmResult.Length</p>
        <p><strong>Total ms:</strong> @_assetWarmResult.TotalMs.ToString("0.00")</p>

        @if (!string.IsNullOrWhiteSpace(_assetWarmResult.Error))
        {
            <p><strong>Error:</strong> @_assetWarmResult.Error</p>
        }
    }

    @if (_runtimeCacheState is not null)
    {
        <p><strong>Raw cached entries:</strong> @_runtimeCacheState.RawAssetCache.EntryCount</p>
        <p><strong>Raw cached bytes:</strong> @_runtimeCacheState.RawAssetCache.TotalBytes</p>
        <p><strong>Processed cache entries:</strong> @_runtimeCacheState.ProcessedAssetCache.EntryCount</p>

        @if (_runtimeCacheState.RawAssetCache.Paths.Length > 0)
        {
            <p><strong>Raw cached paths:</strong> @string.Join(", ", _runtimeCacheState.RawAssetCache.Paths)</p>
        }

        @if (_runtimeCacheState.ProcessedAssetCache.Keys.Length > 0)
        {
            <p><strong>Processed cache keys:</strong> @string.Join(", ", _runtimeCacheState.ProcessedAssetCache.Keys)</p>
        }
    }
</div>

<div class="next-steps">
    <h2>Hues probe</h2>
    <p>This validates `hues.mul` through the same loader harness and cached parse path as the other asset families.</p>

    <div class="mb-2">
        <label><strong>Hues path:</strong></label>
        <input class="form-control" @bind="_huesPath" />
    </div>

    <div class="actions">
        <button class="btn btn-dark" @onclick="ProbeHues" disabled="@_huesBusy">@(_huesBusy ? "Reading..." : "Probe hues file")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_huesMessage))
    {
        <p class="message">@_huesMessage</p>
    }

    @if (_huesProbe is not null)
    {
        <p><strong>Exists:</strong> @FormatBool(_huesProbe.Exists)</p>
        <p><strong>Bytes:</strong> @_huesProbe.Length</p>
        <p><strong>Used parsed cache:</strong> @FormatBool(_huesProbe.UsedParsedCache)</p>
        <p><strong>First group header:</strong> @_huesProbe.FirstGroupHeader</p>
        <p><strong>First palette color16:</strong> @_huesProbe.FirstPaletteColor16</p>
        <p><strong>First hue name:</strong> @(string.IsNullOrWhiteSpace(_huesProbe.FirstHueName) ? "(empty)" : _huesProbe.FirstHueName)</p>
        <p><strong>Total ms:</strong> @_huesProbe.TotalMs.ToString("0.00")</p>

        @if (!string.IsNullOrWhiteSpace(_huesProbe.Error))
        {
            <p><strong>Error:</strong> @_huesProbe.Error</p>
        }
    }
</div>

<div class="next-steps">
    <h2>Cliloc probe</h2>
    <p>This validates a second real asset family through the same browser-backed stream seam used by the tiledata probe.</p>

    <div class="mb-2">
        <label><strong>Cliloc path:</strong></label>
        <input class="form-control" @bind="_clilocPath" />
    </div>

    <div class="actions">
        <button class="btn btn-dark" @onclick="ProbeCliloc" disabled="@_clilocBusy">@(_clilocBusy ? "Reading..." : "Probe cliloc file")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_clilocMessage))
    {
        <p class="message">@_clilocMessage</p>
    }

    @if (_clilocProbe is not null)
    {
        <p><strong>Exists:</strong> @FormatBool(_clilocProbe.Exists)</p>
        <p><strong>Bytes:</strong> @_clilocProbe.Length</p>
        <p><strong>Used processed cache:</strong> @FormatBool(_clilocProbe.UsedProcessedCache)</p>
        <p><strong>Header 1:</strong> @_clilocProbe.Header1</p>
        <p><strong>Header 2:</strong> @_clilocProbe.Header2</p>
        <p><strong>First entry number:</strong> @_clilocProbe.FirstEntryNumber</p>
        <p><strong>First entry flag:</strong> @_clilocProbe.FirstEntryFlag</p>
        <p><strong>First entry text length:</strong> @_clilocProbe.FirstEntryTextLength</p>
        <p><strong>First entry text:</strong> @(string.IsNullOrWhiteSpace(_clilocProbe.FirstEntryText) ? "(empty)" : _clilocProbe.FirstEntryText)</p>
        <p><strong>Total ms:</strong> @_clilocProbe.TotalMs.ToString("0.00")</p>

        @if (!string.IsNullOrWhiteSpace(_clilocProbe.Error))
        {
            <p><strong>Error:</strong> @_clilocProbe.Error</p>
        }
    }
</div>

<div class="next-steps">
    <h2>Tiledata probe</h2>
    <p>This is the first structured binary asset read, using the same file the desktop client currently validates at startup.</p>

    <div class="mb-2">
        <label><strong>Tiledata path:</strong></label>
        <input class="form-control" @bind="_tileDataPath" />
    </div>

    <div class="actions">
        <button class="btn btn-dark" @onclick="ProbeTileData" disabled="@_tileDataBusy">@(_tileDataBusy ? "Reading..." : "Probe tiledata.mul")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_tileDataMessage))
    {
        <p class="message">@_tileDataMessage</p>
    }

    @if (_tileDataProbe is not null)
    {
        <p><strong>Exists:</strong> @FormatBool(_tileDataProbe.Exists)</p>
        <p><strong>Bytes:</strong> @_tileDataProbe.Length</p>
        <p><strong>Old format:</strong> @FormatBool(_tileDataProbe.IsOldFormat)</p>
        <p><strong>First group header:</strong> @_tileDataProbe.Header</p>
        <p><strong>First land flags:</strong> @_tileDataProbe.FirstLandFlags</p>
        <p><strong>First land texture id:</strong> @_tileDataProbe.FirstLandTextureId</p>
        <p><strong>First land name:</strong> @(string.IsNullOrWhiteSpace(_tileDataProbe.FirstLandName) ? "(empty)" : _tileDataProbe.FirstLandName)</p>
        <p><strong>Total ms:</strong> @_tileDataProbe.TotalMs.ToString("0.00")</p>

        @if (!string.IsNullOrWhiteSpace(_tileDataProbe.Error))
        {
            <p><strong>Error:</strong> @_tileDataProbe.Error</p>
        }
    }
</div>
}

@if (_activeTab == "imports")
{
@if (_storage is not null)
{
    <div class="next-steps">
        <h2>Storage smoke test</h2>
        <p><strong>Read text:</strong> @(_storage.ReadText.Length == 0 ? "none" : _storage.ReadText)</p>
        <p><strong>Files:</strong> @(string.Join(", ", _storage.FileNames))</p>
        @if (!string.IsNullOrWhiteSpace(_storage.Error))
        {
            <p><strong>Error:</strong> @_storage.Error</p>
        }
    </div>
}

@if (_storedFiles is not null)
{
    <div class="next-steps">
        <h2>Stored browser files</h2>
        @if (_storedFiles.FileNames.Length == 0)
        {
            <p>No files are stored in OPFS yet.</p>
        }
        else
        {
            <ul>
                @foreach (var fileName in _storedFiles.FileNames)
                {
                    <li>@fileName</li>
                }
            </ul>
        }
        @if (!string.IsNullOrWhiteSpace(_storedFiles.Error))
        {
            <p><strong>Error:</strong> @_storedFiles.Error</p>
        }
    </div>
}

@if (_rootSummaries is not null)
{
    <div class="next-steps">
        <h2>Root summary</h2>
        @foreach (var summary in _rootSummaries)
        {
            <p><strong>@summary.Name (@summary.RootPath):</strong> @summary.FileCount file(s)</p>

            @if (summary.SampleFiles.Length > 0)
            {
                <p><strong>Sample:</strong> @string.Join(", ", summary.SampleFiles)</p>
            }

            @if (!string.IsNullOrWhiteSpace(summary.Error))
            {
                <p><strong>Error:</strong> @summary.Error</p>
            }
        }
    </div>
}

@if (_hostedSeedManifest is not null)
{
    <div class="next-steps">
        <h2>Hosted local seed</h2>
        <p>This is the local disk staging area for bulk asset imports without browser file picking.</p>
        <p><strong>Available:</strong> @FormatBool(_hostedSeedManifest.Available)</p>
        <p><strong>Files:</strong> @_hostedSeedManifest.FileCount</p>
        <p><strong>Total bytes:</strong> @_hostedSeedManifest.TotalBytes</p>

        @if (_hostedSeedManifest.Entries.Length > 0)
        {
            <p><strong>Sample:</strong> @string.Join(", ", _hostedSeedManifest.Entries.Take(8).Select(x => x.RelativePath))</p>
        }

        @if (!string.IsNullOrWhiteSpace(_hostedSeedManifest.Error))
        {
            <p><strong>Error:</strong> @_hostedSeedManifest.Error</p>
        }
    </div>
}

@if (_assetManifest is not null)
{
    <div class="next-steps">
        <h2>Asset manifest</h2>
        <p>This is the first structured view of imported `/uo` files for future browser runtime loading.</p>
        <p><strong>Root:</strong> @_assetManifest.RootPath</p>
        <p><strong>Files:</strong> @_assetManifest.FileCount</p>
        <p><strong>Total bytes:</strong> @_assetManifest.TotalBytes</p>

        @if (_assetManifest.Extensions.Length > 0)
        {
            <p><strong>Extensions:</strong> @string.Join(", ", _assetManifest.Extensions)</p>
        }

        @if (_assetManifest.Entries.Length == 0)
        {
            <p>No `/uo` assets are imported yet.</p>
        }
        else
        {
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Path</th>
                        <th>Extension</th>
                        <th>Bytes</th>
                        <th>Preloaded</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in _assetManifest.Entries.Take(12))
                    {
                        <tr>
                            <td>@entry.Path</td>
                            <td>@entry.Extension</td>
                            <td>@entry.Size</td>
                            <td>@FormatBool(entry.IsPreloaded)</td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (_assetManifest.Entries.Length > 12)
            {
                <p>Showing first 12 of @_assetManifest.Entries.Length entries.</p>
            }
        }

        @if (!string.IsNullOrWhiteSpace(_assetManifest.Error))
        {
            <p><strong>Error:</strong> @_assetManifest.Error</p>
        }
    </div>
}
}

@if (_activeTab == "diagnostics")
{
<div class="next-steps">
    <h2>Virtual path bridge probe</h2>
    <p>This exercises the same kind of virtual-path reads and writes the future browser filesystem provider will need.</p>
    <p><strong>Asset root:</strong> `/uo`</p>

    <div class="mb-2">
        <label><strong>Probe path:</strong></label>
        <input class="form-control" @bind="_bridgePath" />
    </div>

    <div class="mb-2">
        <label><strong>Write text:</strong></label>
        <textarea class="form-control" rows="4" @bind="_bridgeWriteText"></textarea>
    </div>

    <div class="actions">
        <button class="btn btn-info" @onclick="ProbeBridgePath" disabled="@_bridgeBusy">@(_bridgeBusy ? "Reading..." : "Probe virtual path")</button>
        <button class="btn btn-warning ms-2" @onclick="WriteBridgeProbe" disabled="@_bridgeWriteBusy">@(_bridgeWriteBusy ? "Writing..." : "Write probe file")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_bridgeMessage))
    {
        <p class="message">@_bridgeMessage</p>
    }

    @if (_bridgeProbe is not null)
    {
        <p><strong>Exists:</strong> @FormatBool(_bridgeProbe.Exists)</p>
        <p><strong>Bytes:</strong> @_bridgeProbe.ByteLength</p>
        <p><strong>Exists ms:</strong> @_bridgeProbe.ExistsMs</p>
        <p><strong>Text read ms:</strong> @_bridgeProbe.TextReadMs</p>
        <p><strong>Bytes read ms:</strong> @_bridgeProbe.BytesReadMs</p>
        <p><strong>Total probe ms:</strong> @_bridgeProbe.TotalMs</p>
        <p><strong>Preview:</strong> @(string.IsNullOrWhiteSpace(_bridgeProbe.TextPreview) ? "none" : _bridgeProbe.TextPreview)</p>

        @if (!string.IsNullOrWhiteSpace(_bridgeProbe.Error))
        {
            <p><strong>Error:</strong> @_bridgeProbe.Error</p>
        }
    }

    @if (_bridgeWriteResult is not null)
    {
        <p><strong>Last write path:</strong> @_bridgeWriteResult.Path</p>
        <p><strong>Write succeeded:</strong> @FormatBool(_bridgeWriteResult.Succeeded)</p>
        <p><strong>Bytes written:</strong> @_bridgeWriteResult.ByteLength</p>
        <p><strong>Write ms:</strong> @_bridgeWriteResult.WriteMs</p>

        @if (!string.IsNullOrWhiteSpace(_bridgeWriteResult.Error))
        {
            <p><strong>Error:</strong> @_bridgeWriteResult.Error</p>
        }
    }
</div>

<div class="next-steps">
    <h2>Read benchmark</h2>
    <p>This measures repeated reads against a single `/uo/...` path to estimate browser-side asset access cost.</p>

    <div class="mb-2">
        <label><strong>Benchmark path:</strong></label>
        <input class="form-control" @bind="_benchmarkPath" />
    </div>

    <div class="mb-2">
        <label><strong>Iterations:</strong></label>
        <input class="form-control" type="number" min="1" @bind="_benchmarkIterations" />
    </div>

    <div class="actions">
        <button class="btn btn-dark" @onclick="RunBenchmark" disabled="@_benchmarkBusy">@(_benchmarkBusy ? "Benchmarking..." : "Run read benchmark")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_benchmarkMessage))
    {
        <p class="message">@_benchmarkMessage</p>
    }

    @if (_benchmarkResult is not null)
    {
        <p><strong>Path:</strong> @_benchmarkResult.Path</p>
        <p><strong>Exists:</strong> @FormatBool(_benchmarkResult.Exists)</p>
        <p><strong>Iterations:</strong> @_benchmarkResult.Iterations</p>
        <p><strong>Bytes:</strong> @_benchmarkResult.Length</p>
        <p><strong>Total ms:</strong> @_benchmarkResult.TotalMs.ToString("0.00")</p>
        <p><strong>Average ms:</strong> @_benchmarkResult.AverageMs.ToString("0.00")</p>

        @if (!string.IsNullOrWhiteSpace(_benchmarkResult.Error))
        {
            <p><strong>Error:</strong> @_benchmarkResult.Error</p>
        }
    }
</div>

<div class="next-steps">
    <h2>Asset preload cache</h2>
    <p>This is the first browser-memory layer for hot `/uo` files so future provider reads can avoid repeated OPFS access.</p>

    <div class="mb-2">
        <label><strong>Preload path:</strong></label>
        <input class="form-control" @bind="_preloadPath" />
    </div>

    <div class="actions">
        <button class="btn btn-secondary" @onclick="PreloadPath" disabled="@_preloadBusy">@(_preloadBusy ? "Preloading..." : "Preload file")</button>
        <button class="btn btn-outline-danger ms-2" @onclick="ClearPreloadCache" disabled="@_preloadClearBusy">@(_preloadClearBusy ? "Clearing..." : "Clear preload cache")</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_preloadMessage))
    {
        <p class="message">@_preloadMessage</p>
    }

    @if (_preloadResult is not null)
    {
        <p><strong>Path:</strong> @_preloadResult.Path</p>
        <p><strong>Succeeded:</strong> @FormatBool(_preloadResult.Succeeded)</p>
        <p><strong>Bytes:</strong> @_preloadResult.Length</p>
        <p><strong>Preload ms:</strong> @_preloadResult.TotalMs.ToString("0.00")</p>

        @if (!string.IsNullOrWhiteSpace(_preloadResult.Error))
        {
            <p><strong>Error:</strong> @_preloadResult.Error</p>
        }
    }

    @if (_preloadSummary is not null)
    {
        <p><strong>Cached entries:</strong> @_preloadSummary.EntryCount</p>
        <p><strong>Total cached bytes:</strong> @_preloadSummary.TotalBytes</p>

        @if (_preloadSummary.Paths.Length > 0)
        {
            <p><strong>Cached paths:</strong> @string.Join(", ", _preloadSummary.Paths)</p>
        }
    }
</div>
}

@code {
    private BrowserHost.Services.BrowserProbeResult? _probe;
    private BrowserHost.Services.BrowserStorageSmokeTestResult? _storage;
    private BrowserHost.Services.BrowserAssetImportResult? _importResult;
    private BrowserHost.Services.BrowserStoredFilesResult? _storedFiles;
    private BrowserHost.Services.BrowserVirtualFileProbeResult? _bridgeProbe;
    private BrowserHost.Services.BrowserVirtualFileWriteProbeResult? _bridgeWriteResult;
    private BrowserHost.Services.BrowserReadBenchmarkResult? _benchmarkResult;
    private BrowserHost.Services.BrowserPreloadResult? _preloadResult;
    private BrowserHost.Services.BrowserPreloadCacheSummary? _preloadSummary;
    private BrowserHost.Services.BrowserAssetManifestResult? _assetManifest;
    private BrowserHost.Services.BrowserHostedSeedManifestResult? _hostedSeedManifest;
    private BrowserHost.Services.BrowserClientTileDataDetails? _tileDataProbe;
    private BrowserHost.Services.BrowserClientClilocDetails? _clilocProbe;
    private BrowserHost.Services.BrowserClientHuesDetails? _huesProbe;
    private BrowserHost.Services.BrowserRuntimeBootstrapState? _loaderSnapshot;
    private BrowserHost.Services.BrowserAssetWarmResult? _assetWarmResult;
    private BrowserHost.Services.BrowserRuntimeCacheState? _runtimeCacheState;
    private BrowserHost.Services.BrowserVirtualRootSummary[]? _rootSummaries;
    private bool _isBusy;
    private bool _storageBusy;
    private bool _importBusy;
    private bool _directoryImportBusy;
    private bool _resetBusy;
    private bool _refreshBusy;
    private bool _bridgeBusy;
    private bool _bridgeWriteBusy;
    private bool _benchmarkBusy;
    private bool _tileDataBusy;
    private bool _clilocBusy;
    private bool _huesBusy;
    private bool _loaderSnapshotBusy;
    private bool _assetWarmBusy;
    private bool _assetCacheClearBusy;
    private bool _preloadBusy;
    private bool _preloadClearBusy;
    private bool _hostedSeedImportBusy;
    private bool _hostedSeedRecommendedImportBusy;
    private string _message = "Click the probe button to test the browser host.";
    private string _storageMessage = "Run the OPFS smoke test after the environment probe succeeds.";
    private string _importMessage = "Import files after the storage checks succeed.";
    private string _bridgeMessage = "Use the virtual path probe after importing a file or writing a probe file.";
    private string _bridgePath = "/uo/probe.txt";
    private string _bridgeWriteText = "classicuo bridge probe";
    private string _benchmarkPath = "/uo/TestDoc.txt";
    private int _benchmarkIterations = 25;
    private string _benchmarkMessage = "Import a `/uo` file and run the benchmark to measure repeated read cost.";
    private string _tileDataPath = "/uo/tiledata.mul";
    private string _tileDataMessage = "Probe tiledata.mul to validate the first structured browser-side asset read.";
    private string _clilocPath = "/uo/cliloc.enu";
    private string _clilocMessage = "Probe cliloc.enu to validate a second structured browser-side asset read.";
    private string _huesPath = "/uo/hues.mul";
    private string _huesMessage = "Probe hues.mul to validate the next loader-style asset family.";
    private string _loaderSnapshotMessage = "Load the bootstrap snapshot to run the current browser-side asset set together.";
    private string _assetWarmPath = "/uo/cliloc.enu";
    private string _assetWarmMessage = "Warm a file into the C# asset stream cache to avoid repeated browser interop for loader-style reads.";
    private string _preloadPath = "/uo/TestDoc.txt";
    private string _preloadMessage = "Preload a `/uo` file into browser memory to simulate a hot asset cache.";
    private string _activeTab = "current";

    protected override async Task OnInitializedAsync()
    {
        await RunProbe();
        await RefreshFiles();
    }

    private async Task RunProbe()
    {
        _isBusy = true;
        _message = "Running browser environment probe...";

        try
        {
            _probe = await ProbeService.ProbeAsync();
            _message = "Probe completed successfully.";
        }
        catch (Exception ex)
        {
            _message = $"Probe failed: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task RunStorageSmokeTest()
    {
        _storageBusy = true;
        _storageMessage = "Running OPFS smoke test...";

        try
        {
            _storage = await StorageService.RunSmokeTestAsync();
            _storageMessage = string.IsNullOrWhiteSpace(_storage.Error)
                ? "OPFS smoke test completed successfully."
                : $"OPFS smoke test completed with error: {_storage.Error}";
            await RefreshFiles();
        }
        catch (Exception ex)
        {
            _storageMessage = $"OPFS smoke test failed: {ex.Message}";
        }
        finally
        {
            _storageBusy = false;
        }
    }

    private async Task ImportFiles()
    {
        _importBusy = true;
        _importMessage = "Opening file picker for /uo import...";

        try
        {
            _importResult = await StorageService.ImportFilesAsync();
            _importMessage = string.IsNullOrWhiteSpace(_importResult.Error)
                ? $"Imported {_importResult.ImportedCount} file(s) under /uo: {string.Join(", ", _importResult.ImportedFileNames)}"
                : $"Import finished with error: {_importResult.Error}";
            await RefreshFiles();
        }
        catch (Exception ex)
        {
            _importMessage = $"Import failed: {ex.Message}";
        }
        finally
        {
            _importBusy = false;
        }
    }

    private async Task RefreshFiles()
    {
        _refreshBusy = true;

        try
        {
            _storedFiles = await StorageService.ListFilesAsync();
            _rootSummaries = await BridgeService.GetRootSummariesAsync();
            _preloadSummary = await StorageService.GetPreloadCacheSummaryAsync();
            _assetManifest = await StorageService.GetAssetManifestAsync();
            _hostedSeedManifest = await StorageService.GetHostedSeedManifestAsync();
            _runtimeCacheState = await BrowserClientAssetService.GetCacheStateAsync();
        }
        finally
        {
            _refreshBusy = false;
        }
    }

    private async Task ImportDirectory()
    {
        _directoryImportBusy = true;
        _importMessage = "Opening folder picker for /uo import...";

        try
        {
            _importResult = await StorageService.ImportDirectoryAsync();
            _importMessage = string.IsNullOrWhiteSpace(_importResult.Error)
                ? $"Imported {_importResult.ImportedCount} file(s) under /uo: {string.Join(", ", _importResult.ImportedFileNames.Take(10))}{(_importResult.ImportedFileNames.Length > 10 ? " ..." : string.Empty)}"
                : $"Folder import finished with error: {_importResult.Error}";
            await RefreshFiles();
        }
        catch (Exception ex)
        {
            _importMessage = $"Folder import failed: {ex.Message}";
        }
        finally
        {
            _directoryImportBusy = false;
        }
    }

